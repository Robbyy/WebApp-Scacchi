# ==============================================================
# WebApp Scacchi - .gitignore (mono-repo: backend/ + frontend/)
# ==============================================================

# ---------- Backend: Java / Maven / Spring Boot ----------
backend/target/
backend/**/target/
*.class
*.jar
*.war
*.ear
*.log
backend/.mvn/wrapper/maven-wrapper.jar

# Spring Boot / runtime
backend/**/application-local.yml
backend/**/application-local.properties

# Database H2 persistito su file (sviluppo locale)
# Temporaneamente versioniamo il DB H2 principale per condividere lo stato
# tra PC; quando passeremo a Supabase PostgreSQL questa eccezione andra' rimossa.
backend/data/
*.mv.db
*.trace.db
!backend/data/
!backend/data/*.mv.db
backend/data/*.lock.db

# ---------- Frontend: Angular / Node ----------
frontend/node_modules/
frontend/dist/
frontend/tmp/
frontend/out-tsc/
frontend/.angular/
frontend/.angular/cache/
frontend/coverage/
npm-debug.log*
yarn-error.log*
frontend/.npm/

# ---------- Variabili d'ambiente / segreti ----------
.env
.env.*
!.env.example

# ---------- IDE: IntelliJ IDEA ----------
.idea/
*.iml
*.iws
*.ipr
out/

# ---------- IDE: VS Code ----------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# ---------- Claude Code ----------
.claude/settings.local.json

# ---------- Work items / issue task artifacts ----------
docs/work-items/**/*.source.json

# ---------- Sistema operativo ----------
.DS_Store
Thumbs.db
desktop.ini

# ---------- Vari ----------
*.bak
*.tmp
