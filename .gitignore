# ==============================================================
# WebApp Scacchi - .gitignore (mono-repo: backend/ + frontend/)
# ==============================================================

# ---------- Backend: Java / Maven / Spring Boot ----------
backend/target/
backend/**/target/
*.class
*.jar
*.war
*.ear
*.log
backend/.mvn/wrapper/maven-wrapper.jar

# Spring Boot / runtime
backend/**/application-local.yml
backend/**/application-local.properties

# ---------- Frontend: Angular / Node ----------
frontend/node_modules/
frontend/dist/
frontend/tmp/
frontend/out-tsc/
frontend/.angular/
frontend/.angular/cache/
frontend/coverage/
npm-debug.log*
yarn-error.log*
frontend/.npm/

# ---------- Variabili d'ambiente / segreti ----------
.env
.env.*
!.env.example

# ---------- IDE: IntelliJ IDEA ----------
.idea/
*.iml
*.iws
*.ipr
out/

# ---------- IDE: VS Code ----------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# ---------- Sistema operativo ----------
.DS_Store
Thumbs.db
desktop.ini

# ---------- Vari ----------
*.bak
*.tmp
